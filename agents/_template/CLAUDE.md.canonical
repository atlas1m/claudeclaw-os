```bash
cd ~/.claudeclaw-app && env -u VIRTUAL_ENV PATH="/Users/maximejean/.nvm/versions/node/v24.11.1/bin:/opt/homebrew/bin:/usr/bin:/bin" npm run build
launchctl kickstart -k gui/$(id -u)/com.claudeclaw.<PROJECT_ID>
```

